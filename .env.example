# Copy this to .env and fill in values.
# .env is gitignored — never commit real secrets.
# Used by docker compose to inject environment variables into the backstage container.

BACKEND_SECRET=change-me-to-a-random-32-char-string

GITLAB_TOKEN=glpat-your-token-here
GITLAB_OAUTH_CLIENT_ID=your-gitlab-oauth-app-id
GITLAB_OAUTH_CLIENT_SECRET=your-gitlab-oauth-secret
